{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RAT v2",
  "version": "6.1.0",
  "identifier": "com.ratv2.desktop",
  "build": {
    "beforeBuildCommand": "node ./prepare-tauri-frontend.mjs",
    "beforeDevCommand": "node ./prepare-tauri-frontend.mjs",
    "frontendDist": "../tauri-dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "RAT v2",
        "width": 1280,
        "height": 720,
        "minWidth": 760,
        "minHeight": 620,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
